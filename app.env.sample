# ComposeCraft environment configuration

# Timezone
TZ=America/New_York

# Hostname / domain
BASE_HOST_NAME=$HOSTNAME
BASE_DOMAIN_NAME=example.com

# Application secret
APP_SECRET_KEY=changeme_secret_key_min_32_chars

# MongoDB admin credentials
DB_ADMIN_NAME=composecraft
DB_ADMIN_PASS=changeme_admin_password
